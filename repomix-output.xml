        ('Ana Costa', '(11) 96666-6666'),
    ]
    
    for nome, telefone in clientes:
        cursor.execute(
            'INSERT INTO clientes (nome, telefone) VALUES (?, ?)',
            (nome, telefone)
        )
    
    # Insert sample servicos
