        LEFT JOIN clientes c ON a.cliente_id = c.id
        LEFT JOIN servicos s ON a.servico_id = s.id
        WHERE DATE(a.data_hora) = DATE('now')
        AND a.status = 'agendado'
        ORDER BY a.data_hora
    ''').fetchall()
    conn.close()
    return jsonify([dict(ag) for ag in agendamentos])
