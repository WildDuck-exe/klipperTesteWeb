    cursor = conn.cursor()
    cursor.execute('SELECT * FROM clientes WHERE id = ?', (id,))
    cliente = cursor.fetchone()
    conn.close()
    
    if cliente is None:
        return jsonify({'error': 'Cliente not found'}), 404
    
    return jsonify(dict(cliente))

