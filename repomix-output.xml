  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      _loadData();
      _setupRealtimeUpdate();
    });
  }

  void _setupRealtimeUpdate() {
    // Configura o ouvinte para mensagens enquanto o app está aberto (Foreground)
    if (!kIsWeb && (Platform.isAndroid || Platform.isIOS)) {
      FirebaseMessaging.onMessage.listen((RemoteMessage message) {
        debugPrint('Notificação recebida em tempo real: ${message.notification?.title}');
        _refreshData(); // Atualiza a lista e o dashboard automaticamente
      });
    }
  }

  void _loadData() {
    final apiService = Provider.of<ApiService>(context, listen: false);
    _refreshData();
  }

  void _refreshData() {
    final apiService = Provider.of<ApiService>(context, listen: false);
    apiService.fetchAgendaHoje();
    apiService.fetchDashboard(period: _selectedPeriod);
  }

