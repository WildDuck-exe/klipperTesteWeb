  Future<List<dynamic>> getClientes() async {
    final response = await http.get(Uri.parse('$baseUrl/api/clientes'));
    if (response.statusCode == 200) {
      return json.decode(response.body);
    } else {
      throw Exception('Falha ao carregar clientes');
    }
